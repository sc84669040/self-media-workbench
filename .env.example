# Optional overrides. Most settings live in config/local/local.yaml.
SELF_MEDIA_HOME=
SELF_MEDIA_CONFIG_PATH=

# Model credentials. Leave blank to run in sample/mock mode.
OPENAI_API_KEY=
CREATE_STUDIO_WRITING_API_KEY=
CREATE_STUDIO_AUTOFILL_API_KEY=

# Optional channel credentials.
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
YT_DLP_COOKIES_PATH=
BILIBILI_COOKIES_PATH=
NIGHTHAWK_TELEGRAM_BOT_TOKEN=

# Optional external binaries.
YT_DLP_BIN=
TWITTER_BIN=
FUNASR_TRANSCRIBE_SCRIPT=

# Optional service sync. Keep disabled for sample mode.
CREATE_STUDIO_ENABLE_UPSTREAM_RAW_SYNC=0
